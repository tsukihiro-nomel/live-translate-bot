# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: for fast slash command updates while testing
DISCORD_GUILD_ID=

# OpenAI
OPENAI_API_KEY=
# Model choices (defaults match our brainstorm)
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_STT_MODEL_FALLBACK=gpt-4o-transcribe
OPENAI_TRANSLATE_MODEL=gpt-4.1-nano
OPENAI_TRANSLATE_MODEL_FALLBACK=gpt-4.1-mini

# Overlay Web
OVERLAY_PORT=3000
# Token required by the overlay page to connect to WS (simple protection)
OVERLAY_TOKEN=change-me

# Runtime knobs
LOG_LEVEL=info
# milliseconds
SILENCE_FINAL_MS=700
BUBBLE_HOLD_MS=2500
BUBBLE_REMOVE_MS=12000
# limit translation calls while someone keeps talking (0 = only final)
INTERIM_TRANSLATE_EVERY_MS=0
# limit interim transcription calls while someone keeps talking (0 = only final)
INTERIM_STT_EVERY_MS=2500
# Max seconds of a single phrase we will send to STT (safety)
MAX_PHRASE_SECONDS=25
